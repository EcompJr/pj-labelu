---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

type Event = CollectionEntry<"schedule">;

interface Props {
  event: Event;
  mayOpen?: boolean;
}

const { event, mayOpen = false } = Astro.props;
const { title, category, agenda, date, time, local } = event.data;

const hasFinished = date.valueOf() < new Date().valueOf();

const localDate = date.toLocaleDateString("pt-BR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});

// Build the detail page URL
const baseUrl = import.meta.env.BASE_URL;
const eventUrl = `${baseUrl}/agenda/${event.id}/`;

let Content: any = null;
if (mayOpen) {
  Content = (await render(event)).Content;
}
---

<li class="relative pl-8 pb-8 border-l-2 border-accent-500 timeline-item">
  <div
    class="absolute -left-2.5 top-0 w-4 h-4 bg-accent-500 border-2 rounded-full"
    aria-hidden="true"
  >
  </div>

  <article class="bg-surface rounded-xl px-6 py-5 shadow-sm">
    <header class="flex justify-between items-center flex-wrap gap-2 mb-2">
      <time
        datetime={date.toISOString().split("T")[0]}
        class="text-sm text-secondary-text font-bold"
        transition:name={`time-${event.id}`}
      >
        {localDate}
        {time && <span class="font-normal"> · {time}</span>}
      </time>

      <div class="flex gap-1.5 flex-wrap">
        {
          hasFinished && (
            <span
              transition:name={`finished-${event.id}`}
              class="text-xs uppercase tracking-wide px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-accent-800 text-white"
            >
              Realizado
            </span>
          )
        }
        <span
          class="text-xs uppercase tracking-wide px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-raised text-body"
          transition:name={`category-${event.id}`}
        >
          {category}
        </span>
      </div>
    </header>

    <h2
      class="text-xl font-semibold mt-1 mb-2"
      transition:name={`title-${event.id}`}
    >
      <a
        href={eventUrl}
        class="text-title no-underline hover:text-accent-500 transition-colors duration-150"
      >
        {title}
      </a>
    </h2>

    <p
      class="text-sm text-secondary-text mb-3 leading-relaxed"
      transition:name={`description-${event.id}`}
    >
      {agenda}
    </p>

    {
      local && (
        <p
          transition:name={`location-${event.id}`}
          class="flex items-center gap-1.5 text-sm text-secondary-text mb-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0 opacity-60"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          {local}
        </p>
      )
    }

    {
      mayOpen && Content ? (
        <details>
          <summary class="text-sm text-accent-600 cursor-pointer font-semibold py-1 hover:underline list-none">
            Ver detalhes completos
          </summary>
          <div class="prose mt-4 pt-4 border-t border-border">
            <Content />
          </div>
        </details>
      ) : (
        <a
          href={eventUrl}
          class="text-sm text-accent-600 font-semibold no-underline hover:underline inline-block"
        >
          Ver detalhes →
        </a>
      )
    }
  </article>
</li>

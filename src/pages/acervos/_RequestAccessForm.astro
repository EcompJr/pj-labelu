---
import { CONTACT_EMAIL } from "../../consts";

import H2 from "./_H2.astro";

const { id } = Astro.props;
---

<form
  id={id}
  action={`mailto:${CONTACT_EMAIL}`}
  method="post"
  enctype="text/plain"
  aria-label="Formulário de Solicitação de Acesso ao Acervo"
  class="flex flex-col"
  data-request-access-form
  data-destino={CONTACT_EMAIL}
>
  <p>
    Preencha os dados abaixo. Ao clicar em enviar, seu aplicativo de e-mail será
    aberto com o pedido formatado.
  </p>

  <section class="flex flex-col gap-2 my-2">
    <label for="nome" class="font-semibold">Nome Completo</label>
    <input
      type="text"
      id="nome"
      name="nome"
      required
      class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text"
      placeholder="Digite seu nome completo"
    />
  </section>

  <section class="flex flex-col gap-2 my-2">
    <label for="telefone-usuario" class="font-semibold">
      Telefone de Contato
    </label>
    <input
      type="tel"
      id="telefone-usuario"
      name="telefone-usuario"
      required
      class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text"
      placeholder="+55 (75) 91122-3344"
    />
  </section>

  <section class="flex flex-col gap-2 my-2">
    <label for="target-achive" class="font-semibold">Acervo(s) de interesse</label>
    <input
      type="text"
      id="target-achive"
      name="target-achive"
      required
      class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text"
      placeholder="Digite o nome do(s) acervo(s) que deseja acessar"
    />
  </section>

  <section class="flex flex-col gap-2 my-2">
    <label for="motivo" class="font-semibold">
      Motivo do Interesse / Pesquisa
    </label>
    <textarea
      id="motivo"
      name="motivo"
      rows="5"
      required
      class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text resize-y"
      placeholder="Explique brevemente sua pesquisa e quais documentos deseja consultar..."
    ></textarea>
  </section>

  <button
    type="submit"
    class="bg-accent-600 text-white rounded-lg px-6 my-2 py-3 font-bold
            cursor-pointer w-max transition-colors duration-200
            hover:bg-accent-800 border-none max-[720px]:w-full"
  >
    Abrir no e-mail
  </button>
</form>

<script>
  const form = document.querySelector(
    "[data-request-access-form]",
  ) as HTMLFormElement | null;

  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();

      const nome = form.elements.namedItem("nome") as HTMLInputElement;
      const telefoneUsuario = form.elements.namedItem(
        "telefone-usuario",
      ) as HTMLInputElement;
      const motivo = form.elements.namedItem("motivo") as HTMLTextAreaElement;
      const targetAchive = form.elements.namedItem("target-achive") as HTMLInputElement;

      const emailDestino = form.dataset.destino;

      if (!emailDestino) {
        form.submit();
        return;
      }

      const subject = encodeURIComponent(
        `Solicitação de Acesso ao Acervo - ${nome.value}`,
      );
      const body = encodeURIComponent(
        `Nome Completo: ${nome.value}\nTelefone de Contato: ${telefoneUsuario.value}\n\nAcervo(s) de interesse: ${targetAchive.value}\nMotivo da solicitação e documentos de interesse:\n${motivo.value}`,
      );

      window.location.href = `mailto:${emailDestino}?subject=${subject}&body=${body}`;
    });
  }
</script>
